---
import type { Locale } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';
import { navPath } from '../utils/paths';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const productPath = navPath('/shop/product', lang);
const cartPath = navPath('/shop/cart', lang);
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
  <div class="flex items-center justify-between mb-8">
    <h1 class="font-serif text-3xl font-semibold text-earth-800">{t('nav.shop')}</h1>
    <a href={cartPath} class="flex items-center gap-2 px-4 py-2 border border-earth-200 rounded-md text-earth-700 hover:border-forest-400 hover:text-forest-700 transition-colors text-sm">
      <span id="cart-count-badge" class="hidden bg-forest-600 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center"></span>
      {t('shop.cart')}
    </a>
  </div>

  <div id="shop-loading" class="text-center py-20 text-earth-500">{t('shop.loading')}</div>
  <div id="shop-error" class="hidden text-center py-20 text-red-600">{t('shop.error')}</div>
  <div id="shop-products" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>
</section>

<script define:vars={{ productPath, lang, viewLabel: t('shop.viewProduct'), noProductsLabel: t('shop.noProducts') }}>
  const API_BASE = (import.meta.env.PUBLIC_SHOP_API_URL ?? '').replace(/\/$/, '');

  function cartCount() {
    try {
      const items = JSON.parse(localStorage.getItem('iboga-cart') ?? '[]');
      return items.reduce((s, i) => s + i.quantity, 0);
    } catch { return 0; }
  }

  function updateCartBadge() {
    const badge = document.getElementById('cart-count-badge');
    if (!badge) return;
    const n = cartCount();
    if (n > 0) {
      badge.textContent = String(n);
      badge.classList.remove('hidden');
    }
  }

  function renderProducts(products) {
    const grid = document.getElementById('shop-products');
    document.getElementById('shop-loading').classList.add('hidden');
    if (products.length === 0) {
      grid.innerHTML = `<p class="col-span-full text-center text-earth-500 py-12">${noProductsLabel}</p>`;
      grid.classList.remove('hidden');
      return;
    }
    grid.innerHTML = products.map(p => {
      const sku = p.default_sku;
      const price = sku?.gross ?? '';
      const img = sku?.image ?? '';
      const placeholder = `<div class="w-full h-48 bg-earth-100 flex items-center justify-center"><span class="text-5xl">🌿</span></div>`;
      return `<a href="${productPath}?id=${p.uuid}" class="block group bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden border border-earth-100">
        ${img ? `<img src="${img}" alt="${p.name}" class="w-full h-48 object-cover" loading="lazy" />` : placeholder}
        <div class="p-5">
          <h3 class="font-serif font-semibold text-lg text-earth-800 group-hover:text-forest-700 transition-colors">${p.name}</h3>
          ${p.caption ? `<p class="text-sm text-earth-600 mt-1 line-clamp-2">${p.caption}</p>` : ''}
          ${price ? `<p class="text-forest-700 font-semibold mt-3">${price}</p>` : ''}
          <span class="mt-3 inline-block px-3 py-1.5 bg-forest-50 text-forest-700 text-sm font-medium rounded-md group-hover:bg-forest-600 group-hover:text-white transition-colors">${viewLabel} →</span>
        </div>
      </a>`;
    }).join('');
    grid.classList.remove('hidden');
  }

  async function loadProducts() {
    try {
      const res = await fetch(`${API_BASE}/api/v1/shop/products/`, { headers: { hreflang: lang } });
      if (!res.ok) throw new Error(`${res.status}`);
      const data = await res.json();
      const products = (data.results ?? data).map(p => ({
        ...p,
        default_sku: p.skus?.find(s => s.uuid === p.default_sku) ?? p.skus?.[0] ?? null,
      }));
      renderProducts(products);
    } catch {
      document.getElementById('shop-loading').classList.add('hidden');
      document.getElementById('shop-error').classList.remove('hidden');
    }
  }

  updateCartBadge();
  loadProducts();
</script>
