---
import { useTranslations, type Locale } from '../i18n/translations';

interface Props {
  title: string;
  excerpt: string;
  slug: string;
  image?: string;
  date?: string;
  lang: Locale;
}

const { title, excerpt, slug, image, date, lang } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === 'de' ? '' : `/${lang}`;
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border border-earth-100">
  {image && (
    <a href={`${prefix}/blog/${slug}`} class="block overflow-hidden aspect-video">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </a>
  )}
  <div class="p-6">
    {date && (
      <time class="text-xs text-earth-400 font-medium uppercase tracking-wider">{date}</time>
    )}
    <h2 class="mt-2 text-xl font-serif font-semibold text-earth-900 group-hover:text-forest-700 transition-colors leading-snug">
      <a href={`${prefix}/blog/${slug}`}>{title}</a>
    </h2>
    <p class="mt-3 text-earth-600 text-sm leading-relaxed line-clamp-3">{excerpt}</p>
    <a
      href={`${prefix}/blog/${slug}`}
      class="mt-4 inline-flex items-center text-forest-600 text-sm font-medium hover:text-forest-800 transition-colors"
    >
      {t('blog.readmore')} →
    </a>
  </div>
</article>
