---
import { useTranslations, type Locale } from '../i18n/translations';
import { asset, navPath } from '../utils/paths';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

function prefix(path: string) {
  return navPath(path, lang);
}
---

<footer class="bg-earth-900 text-earth-200 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src={asset('/images/logo.png')} alt="Iboga.shop" class="h-10 w-10 rounded-full object-cover" />
          <span class="font-serif text-xl text-white">iboga<span class="text-forest-400">.shop</span></span>
        </div>
        <p class="text-sm text-earth-400 leading-relaxed">
          {t('footer.disclaimer')}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-white font-medium mb-4">Navigation</h3>
        <ul class="space-y-2 text-sm">
          {[
            { key: 'nav.microdosing', path: '/microdosing' },
            { key: 'nav.infos', path: '/wichtigste-infos' },
            { key: 'nav.fullflood', path: '/fullflood' },
            { key: 'nav.treatment', path: '/behandlung' },
            { key: 'nav.blog', path: '/blog' },
            { key: 'nav.videos', path: '/videos' },
            { key: 'nav.sources', path: '/quellen' },
          ].map(({ key, path }) => (
            <li>
              <a href={prefix(path)} class="text-earth-400 hover:text-forest-400 transition-colors">
                {t(key as any)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-medium mb-4">{t('footer.contact')}</h3>
        <div class="space-y-2 text-sm">
          <a
            href="mailto:ibogagermany@protonmail.com"
            class="block text-earth-400 hover:text-forest-400 transition-colors"
          >
            ibogagermany@protonmail.com
          </a>
          <div class="pt-2 flex gap-3">
            <a
              href="https://www.facebook.com/Dellaibogain/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-earth-400 hover:text-forest-400 transition-colors"
              aria-label="Facebook"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a
              href="https://twitter.com/dellaiboga"
              target="_blank"
              rel="noopener noreferrer"
              class="text-earth-400 hover:text-forest-400 transition-colors"
              aria-label="Twitter/X"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a
              href="https://www.youtube.com/@ibogagermanyibogaspirit9352"
              target="_blank"
              rel="noopener noreferrer"
              class="text-earth-400 hover:text-forest-400 transition-colors"
              aria-label="YouTube"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          </div>
          <div class="pt-3">
            <a
              href="https://iboga.store"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-forest-600 text-white text-sm rounded-md hover:bg-forest-700 transition-colors"
            >
              {t('shop.cta')} ↗
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-earth-800 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-earth-500">
      <p>© {new Date().getFullYear()} iboga.shop — {t('footer.disclaimer')}</p>
      <div class="flex gap-4">
        <a href={prefix('/impressum')} class="hover:text-earth-300 transition-colors">{t('footer.imprint')}</a>
        <a href={prefix('/kontakt')} class="hover:text-earth-300 transition-colors">{t('footer.contact')}</a>
      </div>
    </div>
  </div>
</footer>
