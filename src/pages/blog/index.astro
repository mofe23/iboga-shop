---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';

const lang = 'de';

const posts = [
  {
    slug: 'iboga-die-wichtigsten-infos',
    title: 'IBOGA – DIE WICHTIGSTEN INFOS',
    excerpt: 'Was ist Iboga? Wozu kann ich Iboga verwenden? Wie wirkt Iboga? Wir beantworten die häufigsten Fragen – von Wirkung über Dosierung bis hin zur Sicherheit.',
    image: '/images/iboga-infos.jpg',
    date: '23. Juli 2023',
  },
  {
    slug: 'iboga-microdosing-mit-wurzelrinde',
    title: 'IBOGA – MICRODOSING MIT WURZELRINDE',
    excerpt: 'Mikrodosierung kann zu tiefgreifenden inneren Verschiebungen führen. Es fühlt sich an, als seien Sie nach Hause gekommen – zentriert, klar, in Ihrem wahrhaftigsten Zustand.',
    image: '/images/microdosing.jpg',
    date: '25. Juli 2023',
  },
  {
    slug: 'professionelle-iboga-behandlung',
    title: 'PROFESSIONELLE IBOGA-BEHANDLUNG',
    excerpt: 'Iboga gehört nicht in ein Krankenhaus. Ein 4-tägiges professionelles Setting in der Natur – rund um die Uhr betreut von erfahrenen Begleitern.',
    image: '/images/professional-treatment.jpg',
    date: '1. August 2023',
  },
  {
    slug: 'erfahrungsbericht-fullflood',
    title: 'Erfahrungsbericht: Eine Fullflood Erfahrung',
    excerpt: 'Ein persönlicher Bericht über meine erste Iboga Full Flood Behandlung bei Della/IBOGAGermany zu Ostern 2021 in Hessen. Die aussergewöhnlichste Erfahrung meines bisherigen Lebens.',
    image: '/images/fullflood-experience.jpg',
    date: '15. September 2023',
  },
];
---

<Layout
  title="Blog – Iboga Erfahrungsberichte & Informationen"
  description="Erfahrungsberichte, Informationen und Guides zu Iboga – Microdosing, Fullflood, Behandlung und mehr."
  locale="de"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10">
      <h1 class="font-serif text-4xl font-semibold text-earth-900">Blog</h1>
      <p class="mt-3 text-earth-600 text-lg">Erfahrungsberichte, Informationen und Guides zu Iboga</p>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map(post => <BlogCard lang={lang} {...post} />)}
    </div>
  </div>
</Layout>
