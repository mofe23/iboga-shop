---
import Layout from '../../../layouts/Layout.astro';
import BlogCard from '../../../components/BlogCard.astro';

const lang = 'en';
const posts = [
  {
    slug: 'key-information-about-iboga',
    title: 'KEY INFORMATION ABOUT IBOGA',
    excerpt: 'What is iboga? What can I use iboga for? How does iboga work? We answer the most frequently asked questions – from effects and dosage to safety.',
    image: '/images/iboga-infos.jpg',
    date: 'July 23, 2023',
  },
  {
    slug: 'iboga-microdosing-with-root-bark',
    title: 'IBOGA – MICRODOSING WITH ROOT BARK',
    excerpt: 'Microdosing can lead to profound internal shifts. It feels like coming home – centred, clear, in your most authentic state.',
    image: '/images/microdosing.jpg',
    date: 'July 25, 2023',
  },
  {
    slug: 'report-of-a-fullflood-experience',
    title: 'Report of a Full Flood Experience',
    excerpt: 'A personal account of my first iboga full flood treatment during the Easter treatment of Della/IBOGAGermany in April 2021 in Hesse. The most extraordinary experience of my life so far.',
    image: '/images/fullflood-experience.jpg',
    date: 'September 15, 2023',
  },
];
---

<Layout title="Blog – Iboga Information & Experiences" description="Experience reports, information and guides on iboga – microdosing, full flood, treatment and more." locale="en">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10">
      <h1 class="font-serif text-4xl font-semibold text-earth-900">Blog</h1>
      <p class="mt-3 text-earth-600 text-lg">Experience reports, information and guides on iboga</p>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map(post => <BlogCard lang={lang} {...post} />)}
    </div>
  </div>
</Layout>
