---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Book Iboga Treatment – Iboga Germany" description="Professional iboga treatment in nature. 4 days, round-the-clock support. Contact Iboga Germany for a personal quote." image="/images/professional-treatment.jpg" locale="en">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10">
      <h1 class="font-serif text-4xl font-semibold text-earth-900">Book Treatment</h1>
      <p class="mt-4 text-xl text-earth-600">Professional iboga accompaniment – individual, personal, in nature.</p>
    </header>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <div>
        <img src="/images/professional-treatment.jpg" alt="Iboga Treatment" class="w-full rounded-2xl object-cover shadow-md aspect-video mb-6" />
        <div class="space-y-6">
          <section>
            <h2 class="font-serif text-xl font-semibold text-earth-900 mb-3">The Setting</h2>
            <p class="text-earth-700 text-sm leading-relaxed">A house or hotel in nature rented for 4 days. 2 people take care of you alternately around the clock. One person always sits beside your bed, helps you to the bathroom and supports you with everything you need.</p>
          </section>
          <section>
            <h2 class="font-serif text-xl font-semibold text-earth-900 mb-3">Our Recommendation</h2>
            <p class="text-earth-700 text-sm leading-relaxed">Before attempting a flood dose session, we recommend everyone to first try <a href="/en/microdosing" class="text-forest-600 hover:text-forest-800 underline">microdosing with root bark</a>. This way you can gently learn how iboga speaks to you.</p>
          </section>
        </div>
      </div>
      <div class="space-y-6">
        <div class="bg-white border border-earth-200 rounded-2xl p-8 shadow-sm">
          <h2 class="font-serif text-2xl font-semibold text-earth-900 mb-6">Get in Touch</h2>
          <a href="mailto:ibogagermany@protonmail.com" class="flex items-center gap-3 p-4 bg-forest-50 border border-forest-200 rounded-xl hover:bg-forest-100 transition-colors group">
            <svg class="w-5 h-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div>
              <p class="font-medium text-forest-800">ibogagermany@protonmail.com</p>
              <p class="text-xs text-forest-600">Personal reply within 48 hours</p>
            </div>
          </a>
        </div>
        <div class="bg-earth-50 border border-earth-200 rounded-2xl p-6">
          <h3 class="font-semibold text-earth-900 mb-4">What to Expect</h3>
          <ul class="space-y-2 text-sm text-earth-700">
            {[
              '🏡 House in nature for 4 days',
              '👥 2 experienced guides round the clock',
              '🌿 Vegetarian / vegan meals included',
              '🧘 Meditation and yoga',
              '🔥 Rituals: fire, earth, water, wind',
              '📱 Phone detox (recommended)',
              '👕 White clothing for the treatment',
            ].map(item => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>
