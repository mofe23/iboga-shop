---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
const lang = 'fr';
const posts = [
  { slug: 'microdosage-iboga', title: 'IBOGA – MICRODOSAGE AVEC ÉCORCE DE RACINE', excerpt: 'Le microdosage peut conduire à des changements internes profonds. On se sent comme si l\'on rentrait chez soi – centré, clair, dans son état le plus authentique.', image: '/images/microdosing.jpg', date: '25 juillet 2023' },
  { slug: 'infos-importantes-iboga', title: 'IBOGA – LES INFORMATIONS LES PLUS IMPORTANTES', excerpt: 'Qu\'est-ce que l\'iboga ? Comment agit-il ? Nous répondons aux questions les plus fréquemment posées sur l\'iboga.', image: '/images/iboga-infos.jpg', date: '23 juillet 2023' },
];
---

<Layout title="Traitement Iboga en Allemagne – Informations, Accompagnement & Rendez-vous" description="Informations, accompagnement et rendez-vous pour les traitements iboga en Allemagne. Sûr, professionnel et durable." locale="fr">
  <section class="relative min-h-[60vh] flex items-center overflow-hidden bg-earth-900">
    <div class="absolute inset-0">
      <img src="/images/iboga-nature-2.jpg" alt="Iboga Nature" class="w-full h-full object-cover opacity-30" />
      <div class="absolute inset-0 bg-gradient-to-br from-earth-900/90 via-earth-900/70 to-forest-900/80"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20">
      <div class="max-w-2xl">
        <h1 class="font-serif text-4xl sm:text-5xl font-semibold text-white leading-tight">
          Traitement Iboga<br /><span class="text-forest-400">en Allemagne</span>
        </h1>
        <p class="mt-6 text-lg text-earth-300">Informations, accompagnement & rendez-vous pour les traitements iboga.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/fr/microdosage" class="px-6 py-3 bg-forest-600 text-white font-medium rounded-lg hover:bg-forest-700 transition-colors">En savoir plus</a>
          <a href="/fr/contact" class="px-6 py-3 bg-white/10 text-white font-medium rounded-lg hover:bg-white/20 transition-colors border border-white/20">Nous contacter</a>
        </div>
      </div>
    </div>
  </section>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="font-serif text-3xl font-semibold text-earth-900 mb-8">Articles récents</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map(post => <BlogCard lang={lang} {...post} />)}
    </div>
  </section>
</Layout>
