---
import Layout from '../layouts/Layout.astro';
const _b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Kontakt – Iboga Germany"
  description="Kontaktiere Iboga Germany für Informationen zu Behandlungen, Microdosing und Produkten."
  locale="de"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10">
      <h1 class="font-serif text-4xl font-semibold text-earth-900">Kontakt</h1>
      <p class="mt-4 text-xl text-earth-600">
        Wir freuen uns auf deine Nachricht.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <div>
        <div class="space-y-6">
          <div class="bg-white border border-earth-200 rounded-2xl p-6 shadow-sm">
            <h2 class="font-serif text-xl font-semibold text-earth-900 mb-4">E-Mail</h2>
            <a
              href="mailto:ibogagermany@protonmail.com"
              class="flex items-center gap-3 text-forest-700 hover:text-forest-900 transition-colors"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="font-medium">ibogagermany@protonmail.com</span>
            </a>
            <p class="mt-3 text-sm text-earth-600">
              Für alle Anfragen zu Behandlungen, Terminen und allgemeinen Informationen.
              Wir antworten persönlich innerhalb von 48 Stunden.
            </p>
          </div>

          <div class="bg-white border border-earth-200 rounded-2xl p-6 shadow-sm">
            <h2 class="font-serif text-xl font-semibold text-earth-900 mb-4">Social Media</h2>
            <div class="space-y-3">
              <a
                href="https://www.facebook.com/Dellaibogain/"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-earth-700 hover:text-forest-700 transition-colors"
              >
                <svg class="w-5 h-5 text-blue-600 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                <span>Iboga Germany auf Facebook</span>
              </a>
              <a
                href="https://twitter.com/dellaiboga"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-earth-700 hover:text-forest-700 transition-colors"
              >
                <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                <span>@dellaiboga auf Twitter/X</span>
              </a>
              <a
                href="https://www.youtube.com/@ibogagermanyibogaspirit9352"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-earth-700 hover:text-forest-700 transition-colors"
              >
                <svg class="w-5 h-5 text-red-600 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
                <span>IBOGA Germany auf YouTube</span>
              </a>
            </div>
          </div>

          <div class="bg-forest-50 border border-forest-200 rounded-2xl p-6">
            <h2 class="font-serif text-xl font-semibold text-forest-900 mb-3">Iboga Store</h2>
            <p class="text-forest-700 text-sm mb-4">
              Für Produktanfragen (Wurzelrinde, Extrakte, Kapseln) besuche direkt den Iboga Store.
            </p>
            <a
              href="https://iboga.store"
              target="_blank"
              rel="noopener noreferrer"
              class="block text-center px-4 py-2 bg-forest-600 text-white text-sm font-medium rounded-lg hover:bg-forest-700 transition-colors"
            >
              iboga.store ↗
            </a>
          </div>
        </div>
      </div>

      <div>
        <img
          src={`${_b}/images/contact-bg.png`}
          alt="Iboga Kontakt"
          class="w-full rounded-2xl object-cover shadow-md mb-6"
          style="aspect-ratio: 16/10; object-fit: cover;"
        />
        <div class="bg-white border border-earth-200 rounded-2xl p-6 shadow-sm">
          <h3 class="font-semibold text-earth-900 mb-3">Häufige Fragen</h3>
          <div class="space-y-3 text-sm text-earth-700">
            <p>→ <a href="/wichtigste-infos" class="text-forest-600 hover:text-forest-800">Was ist Iboga und wie wirkt es?</a></p>
            <p>→ <a href="/microdosing" class="text-forest-600 hover:text-forest-800">Wie fange ich mit Microdosing an?</a></p>
            <p>→ <a href="/fullflood" class="text-forest-600 hover:text-forest-800">Was kostet eine Fullflood-Behandlung?</a></p>
            <p>→ <a href="/behandlung" class="text-forest-600 hover:text-forest-800">Wie buche ich eine Behandlung?</a></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
