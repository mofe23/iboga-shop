---
import Layout from '../layouts/Layout.astro';

const videos = [
  { id: '7b3HpxO5HRM', title: 'Iboga – Allgemeine Informationen' },
  { id: '6xQFRStz0ic', title: 'Spirituelle Full Flood Session' },
  { id: 'u-T_XAGahA0', title: 'Microdosierung mit Iboga' },
  { id: 'kAa8YNJ9ft4', title: 'Iboga beim Drogen-Entzug' },
  { id: 'QQnhNkFar5c', title: 'Dellas persönliche Erfahrungen mit Ibogain' },
  { id: 'xKR5xFsLR1I', title: 'Beschaffung, Anbau und Anwendung' },
  { id: 'I8UdTDtnMG4', title: 'Iboga Germany – Erfahrungsberichte' },
  { id: 'KOIPs5cnmW0', title: 'Iboga – Vertiefende Informationen' },
];
---

<Layout
  title="Videos – Iboga Informationen & Erfahrungen"
  description="Videos zu allgemeinen Iboga Infos, spirituellen Full Flood Sitzungen, Microdosierung und Dellas persönlichen Erfahrungen mit Ibogain."
  locale="de"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10">
      <h1 class="font-serif text-4xl font-semibold text-earth-900">Videos</h1>
      <p class="mt-3 text-earth-600 text-lg">
        Hier ein paar Videos von unserem YouTube-Kanal zu allgemeinen Iboga-Infos,
        spirituellen Full Flood Sitzungen, Microdosierung und Dellas persönlichen Erfahrungen.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {videos.map(({ id, title }) => (
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-earth-100">
          <div class="aspect-video">
            <iframe
              src={`https://www.youtube.com/embed/${id}`}
              title={title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
          <div class="p-4">
            <h2 class="font-medium text-earth-900">{title}</h2>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a
        href="https://www.youtube.com/@ibogagermanyibogaspirit9352"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        Alle Videos auf YouTube ansehen
      </a>
    </div>
  </div>
</Layout>
